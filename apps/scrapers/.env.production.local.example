# Production DB connection for the LOCAL daily scrape task (scripts/scrape-all.ps1).
#
# Copy this file to `.env.production.local` (which is gitignored) and paste the
# Supabase connection string from:
#   Supabase dashboard -> project inmobi-intel -> Settings -> Database -> Connection string (URI)
#
# This points the local scrape at the SAME Supabase DB the Vercel app reads,
# instead of your local Postgres on :5433.
#
# OJO: el proyecto inmobi-intel es ref `fsrdscqnyufkfxkjfuun` (NO confundir con
# prode-amigos `bhfsibyipezufgzxqaxm`, que es otro proyecto del mismo dueño).
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.fsrdscqnyufkfxkjfuun.supabase.co:5432/postgres

# --- MercadoLibre API oficial (opcional, ver docs/decisions/008) ---
# Dejar vacías hasta dar de alta la app en developers.mercadolibre.com.ar.
# Mientras estén vacías, ML sigue usando el scraper HTML (sin cambios).
ML_APP_ID=
ML_SECRET=
ML_REFRESH_TOKEN=
