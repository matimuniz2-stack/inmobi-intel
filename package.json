{
  "name": "inmobi-intel",
  "version": "0.1.0",
  "private": true,
  "description": "App interna de inteligencia inmobiliaria para Mar del Plata + CABA",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "build": "pnpm -r --if-present build",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "db:up": "docker compose -f infrastructure/docker-compose.yml up -d",
    "db:down": "docker compose -f infrastructure/docker-compose.yml down",
    "db:logs": "docker compose -f infrastructure/docker-compose.yml logs -f postgres",
    "db:reset": "docker compose -f infrastructure/docker-compose.yml down -v && pnpm db:up"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
