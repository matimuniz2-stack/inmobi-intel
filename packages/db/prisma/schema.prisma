// Inmobi Intel — Prisma schema
// Convención: campos camelCase en TS, columnas snake_case en Postgres vía @map.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // En Supabase: DATABASE_URL apunta al pgbouncer transaction pooler (6543);
  // DIRECT_URL apunta al session pooler (5432) y se usa para migrations.
  // En local: DIRECT_URL puede quedar igual a DATABASE_URL o sin definir.
  directUrl = env("DIRECT_URL")
}

enum Portal {
  MERCADOLIBRE
  ARGENPROP
  ZONAPROP
  // Fase 2+: PROPERATI, REMAX
}

enum OperationType {
  SALE
  RENT
  TEMP_RENT
}

enum PropertyType {
  APT
  HOUSE
  PH
  LOCAL
  TERRENO
  OTRO
}

enum Currency {
  ARS
  USD
}

enum ScrapeJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

model Property {
  id String @id @default(uuid()) @db.Uuid

  portal   Portal
  portalId String @map("portal_id")
  url      String
  title    String?

  operationType OperationType @map("operation_type")
  propertyType  PropertyType  @map("property_type")

  priceAmount        Decimal  @map("price_amount") @db.Decimal(14, 2)
  priceCurrency      Currency @map("price_currency")
  priceUsdNormalized Decimal? @map("price_usd_normalized") @db.Decimal(14, 2)

  expensesAmount   Decimal?  @map("expenses_amount") @db.Decimal(14, 2)
  expensesCurrency Currency? @map("expenses_currency")

  bedrooms   Int?
  bathrooms  Int?
  totalSqm   Decimal? @map("total_sqm") @db.Decimal(10, 2)
  coveredSqm Decimal? @map("covered_sqm") @db.Decimal(10, 2)

  addressFull  String?  @map("address_full")
  neighborhood String?
  city         String?
  province     String?
  lat          Decimal? @db.Decimal(9, 6)
  lng          Decimal? @db.Decimal(9, 6)

  photos      Json    @default("[]")
  description String? @db.Text
  amenities   Json    @default("{}")

  agencyName  String? @map("agency_name")
  agencyPhone String? @map("agency_phone")
  agencyEmail String? @map("agency_email")
  agencyUrl   String? @map("agency_url")

  zoneSlug String? @map("zone_slug")

  firstSeenAt   DateTime @default(now()) @map("first_seen_at") @db.Timestamptz
  lastSeenAt    DateTime @default(now()) @map("last_seen_at") @db.Timestamptz
  lastUpdatedAt DateTime @updatedAt @map("last_updated_at") @db.Timestamptz

  isActive Boolean @default(true) @map("is_active")

  priceHistory PriceHistory[]
  opportunity  Opportunity?

  @@unique([portal, portalId])
  @@index([operationType, propertyType, neighborhood])
  @@index([zoneSlug, operationType, priceUsdNormalized])
  @@index([lastSeenAt])
  @@index([isActive])
  @@map("properties")
}

model ScrapeJob {
  id           String          @id @default(uuid()) @db.Uuid
  portal       Portal
  params       Json
  status       ScrapeJobStatus @default(PENDING)
  startedAt    DateTime?       @map("started_at") @db.Timestamptz
  completedAt  DateTime?       @map("completed_at") @db.Timestamptz
  itemsFound   Int             @default(0) @map("items_found")
  itemsCreated Int             @default(0) @map("items_created")
  itemsUpdated Int             @default(0) @map("items_updated")
  errorLog     Json?           @map("error_log")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz

  @@index([portal, status])
  @@index([createdAt])
  @@map("scrape_jobs")
}

model UsdRate {
  id         String   @id @default(uuid()) @db.Uuid
  source     String
  rate       Decimal  @db.Decimal(10, 2)
  recordedAt DateTime @default(now()) @map("recorded_at") @db.Timestamptz

  @@index([recordedAt])
  @@index([source, recordedAt])
  @@map("usd_rates")
}

// Una fila por cada precio observado de una propiedad. El scraper inserta una
// nueva fila sólo cuando el precio cambia respecto de la última observación, así
// el detector de oportunidades puede ver "bajó de X a Y hace N días".
model PriceHistory {
  id         String   @id @default(uuid()) @db.Uuid
  propertyId String   @map("property_id") @db.Uuid
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  priceAmount        Decimal  @map("price_amount") @db.Decimal(14, 2)
  priceCurrency      Currency @map("price_currency")
  priceUsdNormalized Decimal? @map("price_usd_normalized") @db.Decimal(14, 2)

  observedAt DateTime @default(now()) @map("observed_at") @db.Timestamptz

  @@index([propertyId, observedAt])
  @@map("price_history")
}

// Resultado del scorer: una oportunidad vigente por propiedad (recalculada cada
// corrida). score 0-100 + reasons (frases en español, principio de explicabilidad)
// + signals (detalle estructurado por señal, para depurar/auditar el puntaje).
model Opportunity {
  id         String   @id @default(uuid()) @db.Uuid
  propertyId String   @unique @map("property_id") @db.Uuid
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  score   Int
  reasons String[]
  signals Json     @default("{}")

  priceUsdAtScore Decimal? @map("price_usd_at_score") @db.Decimal(14, 2)

  computedAt DateTime @default(now()) @map("computed_at") @db.Timestamptz

  @@index([score])
  @@index([computedAt])
  @@map("opportunities")
}
